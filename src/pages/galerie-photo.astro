---

<BaseLayout
    title="Galerie photos — L'atelier, les stages et l'hébergement"
    description="Galerie photos de l'Atelier Ilys : le lieu, l'atelier et le jardin, les stages de teinture végétale, les créations, le service personnalisé et l'hébergement à Pierrerue."
    canonicalPath="/galerie-photo"
>
    <section class="py-16 bg-cream-dark border-b text-center">
        <div class="max-w-3xl mx-auto px-4">
            <p class="text-ochre text-sm uppercase tracking-widest mb-3">
                Galerie
            </p>
            <h1 class="section-title text-4xl md:text-5xl">Photos</h1>
            <p class="text-warm-text/70 mt-4">
                Découvrez en images le domaine, l'atelier, les stages et les
                créations de l'Atelier Ilys.
            </p>
        </div>
    </section>

    <section class="py-12 bg-cream">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <Gallery sections={gallerySections} />
        </div>
    </section>

    <section class="py-12 bg-indigo text-center text-cream">
        <div class="max-w-2xl mx-auto px-4">
            <h2 class="font-heading text-2xl text-cream mb-4">
                Vous aussi, vivez l'expérience
            </h2>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/initiation" class="btn-ochre">Voir les stages</a>
                <a
                    href="/sejournez"
                    class="btn-secondary border-cream text-cream hover:bg-cream hover:text-indigo"
                    >Séjourner sur place</a
                >
            </div>
        </div>
    </section>
</BaseLayout>
