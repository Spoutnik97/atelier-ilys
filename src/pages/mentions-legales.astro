  <section class="py-16 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 prose prose-sm prose-headings:font-heading prose-headings:text-indigo max-w-none">
      <div class="bg-white p-8 rounded-sm shadow-sm border border-cream-dark space-y-8 text-warm-text/80 leading-relaxed">

