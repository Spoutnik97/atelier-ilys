---
const year = new Date().getFullYear()
---

<footer class="bg-indigo text-cream mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <h3 class="font-heading text-xl text-ochre mb-3">Atelier Ilys</h3>
        <p class="text-cream/80 text-sm leading-relaxed">
          Teintures végétales artisanales en Haute-Provence.<br />
          Stages, hébergement et services personnalisés<br />
          au cœur d'une magnanerie du XVIII<sup>e</sup> siècle.
        </p>
        <div class="mt-4 flex gap-3">
          <a
            href="https://www.facebook.com/atelierteinturevegetal"
            target="_blank"
            rel="noopener noreferrer"
            class="text-cream/60 hover:text-ochre transition-colors"
            aria-label="Facebook Atelier Ilys"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/atelier_ilys"
            target="_blank"
            rel="noopener noreferrer"
            class="text-cream/60 hover:text-ochre transition-colors"
            aria-label="Instagram Atelier Ilys"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-heading text-lg text-ochre mb-3">Navigation</h3>
        <ul class="space-y-2 text-sm text-cream/80">
          <li><a href="/atelier-ilys" class="hover:text-ochre transition-colors">L'atelier</a></li>
          <li><a href="/initiation" class="hover:text-ochre transition-colors">Stages de teinture</a></li>
          <li><a href="/planifiez" class="hover:text-ochre transition-colors">Calendrier 2026</a></li>
          <li><a href="/reserver" class="hover:text-ochre transition-colors">Réserver un stage</a></li>
          <li><a href="/sejournez" class="hover:text-ochre transition-colors">Hébergement</a></li>
          <li><a href="/reserve-ton-sejour" class="hover:text-ochre transition-colors">Réserver un séjour</a></li>
          <li><a href="/galerie-photo" class="hover:text-ochre transition-colors">Galerie photos</a></li>
          <li><a href="/service-personnalise" class="hover:text-ochre transition-colors">Service personnalisé</a></li>
          <li><a href="/boutique" class="hover:text-ochre transition-colors">Boutique</a></li>
          <li><a href="/offrez" class="hover:text-ochre transition-colors">Offrir un cadeau</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-lg text-ochre mb-3">Contact</h3>
        <address class="not-italic text-sm text-cream/80 space-y-2 leading-relaxed">
          <p>
            <span class="font-semibold text-cream">Isabelle Lys</span><br />
            Atelier Ilys<br />
            Chemin de Mane<br />
            04300 Pierrerue (Forcalquier)<br />
            Haute-Provence
          </p>
          <p>
            <a href="tel:+33612345678" class="hover:text-ochre transition-colors">06 12 34 56 78</a>
          </p>
          <p>
            <a href="mailto:atelier.ilys@gmail.com" class="hover:text-ochre transition-colors">atelier.ilys@gmail.com</a>
          </p>
        </address>
        <div class="mt-4">
          <a href="/contact" class="btn-ochre text-sm py-2 px-4">
            Nous écrire
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-cream/20 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-cream/50">
      <p>&copy; {year} Atelier Ilys — Tous droits réservés</p>
      <a href="/mentions-legales" class="hover:text-cream transition-colors">Mentions légales</a>
    </div>
  </div>
</footer>
