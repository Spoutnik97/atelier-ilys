---
interface Props {
  label: string
  url: string
  price?: string
  variant?: 'primary' | 'secondary' | 'ochre'
}

const { label, url, price, variant = 'ochre' } = Astro.props

const btnClass = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  ochre: 'btn-ochre',
}[variant]
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class={`${btnClass} inline-flex items-center gap-2`}
  aria-label={`${label}${price ? ` — ${price}` : ''} (ouvre SumUp dans un nouvel onglet)`}
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
  </svg>
  {label}
  {price && <span class="font-semibold">— {price}</span>}
</a>
