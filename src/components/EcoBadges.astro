---
const badges = [
  {
    icon: '🤲',
    label: 'Fait main',
    description: 'Chaque création est travaillée à la main',
  },
  {
    icon: '♻️',
    label: 'Zéro déchet',
    description: 'Processus pensé pour minimiser les déchets',
  },
  {
    icon: '🌿',
    label: 'Produits naturels',
    description: '100% plantes, minéraux et matières naturelles',
  },
  {
    icon: '💧',
    label: 'Non polluant',
    description: 'Sans produits chimiques de synthèse',
  },
  {
    icon: '☀️',
    label: 'Made in Provence',
    description: 'Créé en Haute-Provence, France',
  },
]
---

<section class="py-10 bg-botanical/10 border-y border-botanical/20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap justify-center gap-6 md:gap-10">
      {badges.map((badge) => (
        <div class="flex flex-col items-center text-center max-w-[120px] group">
          <div class="w-14 h-14 rounded-full bg-cream border-2 border-botanical flex items-center justify-center text-2xl mb-2 group-hover:scale-110 transition-transform">
            {badge.icon}
          </div>
          <span class="text-xs font-semibold text-botanical uppercase tracking-wide">{badge.label}</span>
          <span class="text-xs text-warm-text/60 mt-1 leading-tight hidden sm:block">{badge.description}</span>
        </div>
      ))}
    </div>
  </div>
</section>
