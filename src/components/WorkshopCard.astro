---
interface Props {
  title: string
  description: string
  duration: string
  price: string
  image: string
  imageAlt: string
  type?: string
  link?: string
}

const { title, description, duration, price, image, imageAlt, type = '', link = '/reserver' } = Astro.props

const typeColors: Record<string, string> = {
  indigo: 'bg-indigo text-cream',
  teinture: 'bg-botanical text-cream',
  ecoprint: 'bg-terracotta text-cream',
  pigments: 'bg-ochre text-cream',
  famille: 'bg-indigo-light text-cream',
  'beaux-arts': 'bg-warm-text text-cream',
}
const badgeClass = typeColors[type] || 'bg-ochre text-cream'
---

<article class="card flex flex-col h-full hover:shadow-md transition-shadow duration-200">
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
      loading="lazy"
      decoding="async"
    />
    {type && (
      <span class={`absolute top-3 left-3 text-xs font-semibold px-2 py-1 rounded ${badgeClass} uppercase tracking-wide`}>
        {type}
      </span>
    )}
  </div>
  <div class="p-5 flex flex-col flex-1">
    <h3 class="font-heading text-xl text-indigo mb-2">{title}</h3>
    <p class="text-warm-text/80 text-sm leading-relaxed flex-1 mb-4">{description}</p>
    <div class="flex items-center justify-between pt-3 border-t border-cream-dark">
      <div class="text-sm text-warm-text/60">
        <span class="font-medium text-warm-text">{duration}</span>
      </div>
      <div class="text-right">
        <span class="font-heading text-lg text-ochre font-semibold">{price}</span>
      </div>
    </div>
    <a href={link} class="btn-primary mt-4 text-sm text-center">
      Réserver ce stage
    </a>
  </div>
</article>
